{
  "name": "experion-ui-tests",
  "version": "1.0.0",
  "description": "Playwright Cucumber BDD + Vite UI testing framework for Experion Technologies",
  "private": true,
  "scripts": {
    "test:e2e": "cucumber-js",
    "test:qa": "cross-env ENV=qa cucumber-js",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:all": "npm run test:unit && npm run test:e2e",
    "report:allure": "allure generate allure-results --clean -o reports/allure-report && allure open reports/allure-report",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.8.0",
    "@cucumber/html-formatter": "^21.3.1",
    "@playwright/test": "^1.44.0",
    "@types/dotenv": "^6.1.1",
    "@types/node": "^20.14.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitest/coverage-v8": "^1.6.1",
    "allure-commandline": "^2.29.0",
    "allure-cucumberjs": "^2.15.0",
    "allure-playwright": "^2.15.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "playwright": "^1.44.0",
    "prettier": "^3.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.12",
    "vitest": "^1.6.1"
  }
}
