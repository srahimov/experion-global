{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@pages/*":       ["src/pages/*"],
      "@components/*":  ["src/components/*"],
      "@fixtures/*":    ["src/fixtures/*"],
      "@utils/*":       ["src/utils/*"],
      "@config/*":      ["src/config/*"],
      "@types-local/*": ["src/types/*"]
    }
  },
  "include": ["src/**/*", "*.ts"],
  "exclude": ["node_modules", "dist", "reports"]
}